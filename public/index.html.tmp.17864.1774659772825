async function loadAllProducts() {
  const el = document.getElementById('dropdownItems');
  if (el) el.innerHTML = '<div class="empty-hint">載入中…</div>';
  try {
    const res = await fetch(PRODUCT_API);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const all = await res.json();
    products = parseProducts(all);
  } catch (err) {
    // CORS 或網路問題時直接用內嵌資料
    products = parseProducts(STATIC_PRODUCTS);
  }
  renderDropdownItems(products);
}

