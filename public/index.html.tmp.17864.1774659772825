let dispatches = []; // [{ id, time, items: { code: { name, icon, unit, batches, returned: null } }, status:'out'|'done', anomaly }]

async function submitGo() {
  const items = {};
  Object.entries(selected).forEach(([code, it]) => {
    items[code] = { ...it, returned: null };
  });
  const today = new Date().toISOString().slice(0, 10);
  const time  = new Date().toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit' });
  const rec = {
    id: Date.now(),
    time,
    note: document.getElementById('goNote').value,
    items,
    status: 'out',
    anomaly: false,
  };
  dispatches.unshift(rec);
  closeSheet();
  setTimeout(() => {
    showToast('✓ 出門登記完成！');
    renderHomeRecords();
    renderLogPage();
    updateStats();
  }, 420);
  // 同步到伺服器
  try {
    const res = await fetch('/api/dispatches', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ driver: DRIVER_NAME, date: today, time, note: rec.note, items }),
    });
    if (res.ok) {
      const data = await res.json();
      rec.serverId = data.id;
    }
  } catch (e) {
    console.warn('[Server sync] submitGo failed:', e);
  }
}

