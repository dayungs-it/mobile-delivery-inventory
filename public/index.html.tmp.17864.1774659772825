function submitRet() {
  // 回庫品項寫回 dispatches（同時儲存每批次繳回數）
  Object.entries(retSelected).forEach(([code, it]) => {
    const returned = it.returnBatches.reduce((a, b) => a + b.qty, 0);
    dispatches.forEach(d => {
      if (d.status === 'out' && d.items[code]) {
        d.items[code].returned = returned;
        d.items[code].returnBatches = JSON.parse(JSON.stringify(it.returnBatches));
      }
    });
  });
  dispatches.forEach(d => {
    if (d.status === 'out') {
      const allDone = Object.values(d.items).every(it => it.returned !== null);
      if (allDone) d.status = 'done';
    }
  });
  // 退換貨記錄另存
  if (Object.keys(rtnSelected).length) {
    const rtnRec = {
      id: Date.now(),
      time: new Date().toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit' }),
      type: 'return',
      items: rtnSelected,
    };
    dispatches.unshift(rtnRec);
  }
  // 產生報表（傳入本次回庫資料與訂單核對結果）
  generateReport(retSelected, rtnSelected, lastOrderMap);
  // 同步回庫資料到伺服器
  const _retTime = new Date().toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit' });
  dispatches.forEach(async d => {
    if (!d.serverId) return;
    try {
      await fetch(`/api/dispatches/${d.serverId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          return_time:  d.status === 'done' ? _retTime : null,
          items:        d.items,
          return_goods: rtnSelected,
          status:       d.status,
        }),
      });
    } catch (e) {
      console.warn('[Server sync] submitRet failed:', e);
    }
  });
  closeSheet();
  setTimeout(() => {
    showToast('✓ 回庫登記完成！報表已更新');
    renderHomeRecords();
    renderLogPage();
    updateStats();
  }, 420);
}

// 儲存最後一次訂單核對結果供報表使用
let lastOrderMap = null;

// ── 產生配送報表 ──
function generateReport(retSel, rtnSel, orderMap) {
  const now = new Date();
  const timeStr = now.toLocaleString('zh-TW', { month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  document.getElementById('reportSub').textContent = `${DRIVER_NAME} · ${timeStr}`;

  // 彙整每個品項的六個數字
  const items = {};

  // 帶出、應繳回、實際繳回
  Object.entries(retSel).forEach(([code, it]) => {
    const taken    = it.takenBatches.reduce((a, b) => a + b.qty, 0);
    const returned = it.returnBatches.reduce((a, b) => a + b.qty, 0);
    const orderQty = orderMap ? (orderMap[code]?.total_qty ?? null) : null;
    const shouldReturn = orderQty !== null ? taken - orderQty : null;
    const diff     = shouldReturn !== null ? returned - shouldReturn : null;
    items[code] = {
      name: it.name, icon: it.icon, unit: it.unit,
      taken, orderQty, shouldReturn, returned, diff,
      returnQty: 0,
    };
  });

  // 退換貨數量
  Object.entries(rtnSel).forEach(([code, it]) => {
    const qty = it.batches.reduce((a, b) => a + b.qty, 0);
    if (items[code]) {
      items[code].returnQty = qty;
    } else {
      items[code] = {
        name: it.name, icon: it.icon, unit: it.unit,
        taken: 0, orderQty: null, shouldReturn: null, returned: 0, diff: null,
        returnQty: qty,
      };
    }
  });

  // 彙總數字
  let totalTaken = 0, totalOrder = 0, totalShould = 0, totalReturned = 0, totalDiff = 0, totalReturn = 0;
  Object.values(items).forEach(it => {
    totalTaken    += it.taken;
    totalOrder    += it.orderQty ?? 0;
    totalShould   += it.shouldReturn ?? 0;
    totalReturned += it.returned;
    totalDiff     += it.diff ?? 0;
    totalReturn   += it.returnQty;
  });

  // 彙總卡片
  const summaryHTML = `
    <div class="report-summary">
      <div class="summary-card">
        <div class="summary-card-label">帶出</div>
        <div class="summary-card-num">${totalTaken}</div>
      </div>
      <div class="summary-card">
        <div class="summary-card-label">訂單</div>
        <div class="summary-card-num">${totalOrder}</div>
      </div>
      <div class="summary-card">
        <div class="summary-card-label">應繳回</div>
        <div class="summary-card-num">${totalShould}</div>
      </div>
      <div class="summary-card">
        <div class="summary-card-label">實際繳回</div>
        <div class="summary-card-num">${totalReturned}</div>
      </div>
      <div class="summary-card">
        <div class="summary-card-label">差異</div>
        <div class="summary-card-num ${totalDiff > 0 ? 'ok' : totalDiff < 0 ? 'warn' : ''}">${totalDiff > 0 ? '+' : ''}${totalDiff}</div>
      </div>
      <div class="summary-card">
        <div class="summary-card-label">收退換貨</div>
        <div class="summary-card-num gold">${totalReturn}</div>
      </div>
    </div>`;

  // 明細表格
  const tableRows = Object.entries(items).map(([code, it]) => {
    const isAnomaly = it.diff !== null && it.diff !== 0;
    return `<tr class="${isAnomaly ? 'anomaly' : ''}">
      <td>${it.icon} ${it.name}</td>
      <td>${it.taken || '-'}</td>
      <td>${it.orderQty ?? '-'}</td>
      <td>${it.shouldReturn ?? '-'}</td>
      <td>${it.returned || '-'}</td>
      <td class="${it.diff > 0 ? 'num-ok' : it.diff < 0 ? 'num-warn' : ''}">${it.diff !== null ? (it.diff > 0 ? '+' : '') + it.diff : '-'}</td>
      <td class="${it.returnQty > 0 ? 'num-gold' : ''}">${it.returnQty || '-'}</td>
    </tr>`;
  }).join('');

  document.getElementById('reportContent').innerHTML = `
    ${summaryHTML}
    <div class="report-section" style="margin-top:14px">
      <div class="report-section-title">品項明細</div>
      <div style="overflow-x:auto">
        <table class="report-table">
          <thead>
            <tr>
              <th>品項</th>
              <th>帶出</th>
              <th>訂單</th>
              <th>應繳</th>
              <th>實繳</th>
              <th>差異</th>
              <th>退換</th>
            </tr>
          </thead>
          <tbody>${tableRows}</tbody>
        </table>
      </div>
    </div>`;
}

// ── 呼叫訂單 API ──
let DRIVER_NAME = sessionStorage.getItem('driverName') || '';

async function fetchOrderData(productCodes) {
  const today = new Date().toISOString().slice(0, 10);
  const res = await fetch(`/api/orders?date=${today}&driver=${encodeURIComponent(DRIVER_NAME)}`);
  if (!res.ok) throw new Error(`API 錯誤 ${res.status}`);
  const list = await res.json();

  console.log(`[訂單API] 共 ${list.length} 筆`);
  const drivers = [...new Set(list.map(r => r.driver_name))];
  console.log('[訂單API] driver_name 值:', drivers);

  const codeSet = new Set(productCodes);
  const orderMap = {};

  list.forEach(row => {
    // 排除換貨-收回（這類不列入訂單統計）
    if (row.item_type === '換貨-收回') return;
    // 前端篩選配送者
    if (row.driver_name !== DRIVER_NAME) return;
    // 只統計在帶出清單內的品項
    if (!codeSet.has(row.product_code)) return;

    if (!orderMap[row.product_code]) {
      orderMap[row.product_code] = { total_qty: 0, clients: [] };
    }
    orderMap[row.product_code].total_qty += (row.qty || 0);
    orderMap[row.product_code].clients.push({
      client_name: row.client_name,
      order_no: row.order_no,
      qty: row.qty,
      unit: row.unit,
    });
  });

  console.log('[訂單API] orderMap:', JSON.stringify(orderMap, null, 2));
  return orderMap;
}

// ── 動態渲染訂單核對區塊 ──
function renderOrderCompare(returnedData, orderMap, errMsg) {
  const now = new Date().toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit' });
  const orderBlock = document.getElementById('orderBlock');

  let hasAnomaly = false;
  const rows = Object.entries(returnedData).map(([code, d]) => {
    // 收退換貨獨立顯示
    if (d.isReturn) {
      return `<div class="order-row" style="border-left:3px solid var(--gold-dark)">
        <div class="order-row-top">
          <div class="order-pname">${d.icon} ${d.name}</div>
          <div style="font-size:11px;font-weight:700;color:var(--gold-dark);background:var(--gold-light);padding:2px 8px;border-radius:20px">收退換貨</div>
        </div>
        <div class="order-compare">
          <div class="oc-item ok">收回 <span>${d.returned}</span></div>
          <div class="oc-item ok">已入庫 <span>✓</span></div>
        </div>
      </div>`;
    }

    const orderInfo    = orderMap ? (orderMap[code] || null) : null;
    const orderQty     = orderInfo ? orderInfo.total_qty : null;
    const shouldReturn = orderQty !== null ? d.taken - orderQty : null;
    const diff         = shouldReturn !== null ? d.returned - shouldReturn : null;
    const isAnomaly    = diff !== null && diff !== 0;
    if (isAnomaly) hasAnomaly = true;

    const diffLabel = diff === null
      ? `<div class="oc-item"><span style="color:var(--text-3)">無訂單資料</span></div>`
      : diff === 0
        ? `<div class="oc-item">差異 <span style="color:var(--text-3)">0</span></div>`
        : diff > 0 ? `<div class="oc-item ok">差異 <span>+${diff}</span></div>` : `<div class="oc-item warn">差異 <span>${diff}</span></div>`;

    return `<div class="order-row">
      <div class="order-row-top">
        <div class="order-pname">${d.icon} ${d.name}</div>
        ${isAnomaly ? '<div class="anomaly-badge">⚠ 異常</div>' : ''}
      </div>
      <div class="order-compare" style="flex-wrap:wrap;gap:6px 14px;">
        <div class="oc-item">帶出 <span>${d.taken}</span></div>
        <div class="oc-item">繳回 <span>${d.returned}</span></div>
        ${orderQty !== null ? `<div class="oc-item">訂單 <span>${orderQty}</span></div>` : ''}
        ${shouldReturn !== null ? `<div class="oc-item ${isAnomaly ? 'warn' : ''}">應繳回 <span>${shouldReturn}</span></div>` : ''}
        ${diffLabel}
      </div>
    </div>`;
  }).join('');

  const errBanner = errMsg
    ? `<div style="background:var(--warn-bg);border:1px solid #f0c040;border-radius:8px;padding:9px 12px;font-size:12px;color:var(--warning);margin-bottom:10px;">⚠ 訂單 API 查詢失敗（${errMsg}），僅顯示帶出／繳回，仍可送出。</div>`
    : '';

  orderBlock.innerHTML = `
    ${errBanner}
    <div class="order-hd">
      <div class="order-hd-label">📋 訂單核對 — ${DRIVER_NAME}</div>
      <div class="order-hd-time">${now}</div>
    </div>
    <div class="order-rows">${rows}</div>`;

  // 若有異常，備註欄提示
  const noteEl = document.getElementById('retNote');
  if (hasAnomaly && noteEl && !noteEl.value) {
    noteEl.placeholder = '偵測到數量差異，請說明原因（主管可見）…';
  }
  // 儲存供報表使用
  lastOrderMap = orderMap;
}


function switchPage(pgId, nvId) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(pgId).classList.add('active');
  document.querySelectorAll('.nitem').forEach(n => n.classList.remove('active'));
  if (nvId) document.getElementById(nvId).classList.add('active');
}

let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
}

// 初始化 spin 動畫 CSS
const style = document.createElement('style');
style.textContent = '@keyframes spin { to { transform: rotate(360deg); } }';
document.head.appendChild(style);

// ── 載入今日紀錄（開啟 app 時從伺服器還原）──
async function loadTodayDispatches() {
  if (!DRIVER_NAME) return;
  try {
    const today = new Date().toISOString().slice(0, 10);
    const res = await fetch(`/api/dispatches/raw?date=${today}&driver=${encodeURIComponent(DRIVER_NAME)}`);
    if (!res.ok) return;
    const rows = await res.json();
    if (!rows.length) return;
    dispatches = rows.map(row => ({
      id:       row.id,
      serverId: row.id,
      time:     row.departure_time,
      note:     row.note || '',
      items:    row.items || {},
      status:   row.status,
      anomaly:  false,
    }));
    renderHomeRecords();
    renderLogPage();
    updateStats();
  } catch (e) {
    console.warn('[loadTodayDispatches]', e);
  }
}

// ── 登入 ──
function doLogin() {
  const name = document.getElementById('loginInput').value.trim();
  if (!name) {
    document.getElementById('loginInput').style.borderColor = '#e74c3c';
    return;
  }
  DRIVER_NAME = name;
  sessionStorage.setItem('driverName', name);
  document.getElementById('loginOverlay').style.display = 'none';
  document.getElementById('hdName').textContent = name;
  document.getElementById('hdAvatar').textContent = name[1] || name[0];
  loadTodayDispatches();
}

// Enter 鍵送出登入
document.getElementById('loginInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') doLogin();
});

// ── 初始化 ──
if (DRIVER_NAME) {
  document.getElementById('loginOverlay').style.display = 'none';
  document.getElementById('hdName').textContent = DRIVER_NAME;
  document.getElementById('hdAvatar').textContent = DRIVER_NAME[1] || DRIVER_NAME[0];
  loadTodayDispatches();
}
