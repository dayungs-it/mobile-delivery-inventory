<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>餐飲配送庫存管理</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
:root {
  --green:       #134532;
  --green-mid:   #1c5e44;
  --green-light: #e8f0eb;
  --green-pale:  #f2f6f3;
  --gold:        #D5C78C;
  --gold-dark:   #b8a96a;
  --gold-light:  #faf7ed;
  --gold-border: #e8ddb0;
  --bg:          #f0f2f0;
  --surface:     #ffffff;
  --border:      #dde3de;
  --text:        #111c17;
  --text-2:      #4a5c52;
  --text-3:      #8a9e92;
  --success:     #2e7d52;
  --warning:     #b8860b;
  --danger:      #c0392b;
  --danger-bg:   #fdecea;
  --warn-bg:     #fdf8e1;
  --radius:      14px;
  --radius-sm:   9px;
}
html {
  height: 100%;
}
body {
  min-height: 100%;
  background: #e8ecef;
  margin: 0;
  padding: 0;
  font-family: 'Noto Sans TC','PingFang TC','Microsoft JhengHei',sans-serif;
  display: flex;
  justify-content: center;
}
.phone {
  width: 100%;
  max-width: 480px;
  min-height: 100vh;
  background: var(--bg);
  position: relative;
  flex-shrink: 0;
}

/* Header */
.hd { background: var(--green); padding: 52px 18px 0; position: sticky; top: 0; z-index: 100; }
.hd-top { display: flex; align-items: flex-start; justify-content: space-between; padding-bottom: 14px; }
.hd-greet { color: rgba(255,255,255,.6); font-size: 12px; margin-bottom: 3px; }
.hd-name { color: #fff; font-size: 20px; font-weight: 700; }
.avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--gold); display: flex; align-items: center; justify-content: center; color: var(--green); font-size: 14px; font-weight: 800; flex-shrink: 0; }


/* Quick btns */
.quick-row { margin: 14px 14px 0; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.qbtn { border-radius: var(--radius); padding: 16px 14px; display: flex; flex-direction: column; gap: 8px; cursor: pointer; transition: transform .13s; border: none; text-align: left; }
.qbtn:active { transform: scale(.97); }
.qbtn.go { background: var(--green); }
.qbtn.ret { background: var(--gold-light); border: 1.5px solid var(--gold-border); }
.qbtn-icon { width: 34px; height: 34px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 17px; }
.qbtn.go .qbtn-icon { background: rgba(255,255,255,.15); }
.qbtn.ret .qbtn-icon { background: rgba(213,199,140,.35); }
.qbtn-title { font-size: 14px; font-weight: 700; }
.qbtn.go .qbtn-title { color: #fff; }
.qbtn.ret .qbtn-title { color: var(--green); }
.qbtn-sub { font-size: 11px; }
.qbtn.go .qbtn-sub { color: rgba(255,255,255,.6); }
.qbtn.ret .qbtn-sub { color: var(--text-3); }

/* Section */
.sec { margin: 18px 14px 0; }
.sec-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.sec-title { font-size: 12px; font-weight: 700; color: var(--text-3); text-transform: uppercase; letter-spacing: .6px; }
.sec-link { font-size: 12px; color: var(--green-mid); font-weight: 600; cursor: pointer; }

/* 今日紀錄卡 */
.dispatch-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm);
  padding: 12px 14px; margin-bottom: 8px; cursor: pointer; transition: border-color .15s;
}
.dispatch-card:active { border-color: var(--green); }
.dc-top { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.dc-tag { font-size: 11px; font-weight: 700; padding: 2px 9px; border-radius: 20px; flex-shrink: 0; }
.dc-tag.out  { background: #fdf3e0; color: var(--warning); }
.dc-tag.done { background: #e6f4ee; color: var(--success); }
.dc-tag.warn { background: var(--danger-bg); color: var(--danger); }
.dc-time { font-size: 11px; color: var(--text-3); margin-left: auto; }
.dc-items { display: flex; flex-direction: column; gap: 6px; }
.dc-item-name { font-size: 13px; font-weight: 700; color: var(--text); margin-top: 4px; }
.dc-item-name:first-child { margin-top: 0; }
.dc-batch-row { display: flex; align-items: center; justify-content: space-between; padding: 4px 0 4px 10px; border-left: 2px solid var(--border); }
.dc-batch-exp { font-size: 11px; color: var(--text-3); font-family: monospace; }
.dc-batch-nums { display: flex; align-items: center; gap: 5px; flex-shrink: 0; }
.dc-batch-tag { font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 10px; }
.dc-batch-tag.out { background: #fdf3e0; color: var(--warning); }
.dc-batch-tag.ret { background: #e6f4ee; color: var(--success); }
.dc-batch-tag.rtn { background: var(--gold-light); color: var(--gold-dark); }
.dc-batch-tag.pending { background: var(--danger-bg); color: var(--danger); }
.dc-batch-num { font-size: 12px; font-weight: 700; color: var(--text); min-width: 20px; text-align: right; }
.dc-row { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-2); }
.dc-row-bold { font-weight: 700; color: var(--text); }
.dc-bottom { margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
.dc-consume { font-size: 12px; color: var(--text-3); }
.dc-consume span { font-weight: 700; color: var(--green); }
.dc-anomaly { font-size: 11px; color: var(--danger); font-weight: 600; }

/* Bottom Nav */
.bnav { position: fixed; bottom: 0; left: 0; right: 0; width: 100%; max-width: 480px; margin: 0 auto; background: var(--surface); border-top: 1px solid var(--border); display: flex; padding: 8px 0 22px; z-index: 200; }
.nitem { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; cursor: pointer; padding: 4px 0; }
.nitem-icon { font-size: 20px; line-height: 1; color: var(--text-3); }
.nitem-label { font-size: 10px; color: var(--text-3); }
.nitem.active .nitem-icon { color: var(--green); }
.nitem.active .nitem-label { color: var(--green); font-weight: 700; }

/* Overlay & Sheet */
.overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.52); z-index: 300; }
.overlay.show { display: block; }
.sheet { position: fixed; bottom: -100%; left: 0; right: 0; width: 100%; max-width: 480px; margin: 0 auto; background: var(--surface); border-radius: 20px 20px 0 0; z-index: 400; transition: bottom .36s cubic-bezier(.32,.72,0,1); height: 88vh; display: flex; flex-direction: column; overflow: hidden; }
.sheet.show { bottom: 0; }
.sheet-handle { width: 36px; height: 4px; background: var(--border); border-radius: 2px; margin: 12px auto 0; flex-shrink: 0; }
.sheet-head { padding: 14px 18px 13px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); border-radius: 20px 20px 0 0; flex-shrink: 0; }
.sheet-title { font-size: 16px; font-weight: 700; color: var(--text); }
.sheet-badge { font-size: 12px; color: var(--text-3); background: var(--green-pale); padding: 3px 10px; border-radius: 20px; }
.sheet-close { width: 28px; height: 28px; border-radius: 50%; background: var(--bg); border: none; display: flex; align-items: center; justify-content: center; font-size: 15px; color: var(--text-2); cursor: pointer; }
.sheet-body { padding: 14px 18px; flex: 1; overflow-y: auto; padding-bottom: 32px; }

/* Step tabs */
.step-tabs { display: flex; gap: 0; background: var(--bg); border-radius: var(--radius-sm); padding: 3px; margin-bottom: 16px; }
.stab { flex: 1; text-align: center; padding: 7px 0; font-size: 12px; font-weight: 600; color: var(--text-3); border-radius: 7px; transition: all .2s; }
.stab.active { background: var(--green); color: #fff; }
.stab.done { color: var(--success); }

/* 搜尋 */
.search-wrap { position: relative; margin-bottom: 10px; }
.search-icon { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); color: var(--text-3); font-size: 15px; pointer-events: none; }
.search-input { width: 100%; background: var(--bg); border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px 10px 34px; font-size: 14px; color: var(--text); font-family: inherit; outline: none; transition: border-color .15s; }
.search-input:focus { border-color: var(--green); }
.search-input::placeholder { color: var(--text-3); }

/* 結果列表 */
.rlist { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; min-height: 60px; }
.ritem { display: flex; align-items: center; gap: 10px; padding: 10px 12px; background: var(--bg); border-radius: var(--radius-sm); cursor: pointer; border: 1.5px solid transparent; transition: all .12s; }
.ritem:hover, .ritem:active { background: var(--green-light); border-color: var(--green); }
.ri-ico { font-size: 18px; }
.ri-info { flex: 1; min-width: 0; }
.ri-name { font-size: 13px; font-weight: 600; color: var(--text); }
.ri-code { font-size: 11px; color: var(--text-3); margin-top: 1px; }
.ri-add { width: 26px; height: 26px; border-radius: 50%; background: var(--green); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 300; line-height: 1; flex-shrink: 0; }

/* 已選品項區塊 */
.sel-wrap { background: var(--green-pale); border: 1.5px solid var(--green-light); border-radius: var(--radius); padding: 12px 13px; margin-bottom: 14px; }
.sel-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.sel-hd-label { font-size: 12px; font-weight: 700; color: var(--green); text-transform: uppercase; letter-spacing: .5px; }
.sel-count { background: var(--green); color: var(--gold); font-size: 11px; font-weight: 800; padding: 2px 9px; border-radius: 20px; }

/* 品項列（含多效期） */
.sel-item { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px 11px; margin-bottom: 7px; }
.sel-item:last-child { margin-bottom: 0; }
.si-top { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.si-ico { font-size: 16px; }
.si-name { font-size: 13px; font-weight: 600; color: var(--text); flex: 1; }
.si-del { width: 22px; height: 22px; border-radius: 50%; background: var(--danger-bg); border: none; display: flex; align-items: center; justify-content: center; font-size: 11px; cursor: pointer; color: var(--danger); flex-shrink: 0; }

/* 效期批次列 */
.batch-list { display: flex; flex-direction: column; gap: 6px; }
.batch-row { display: flex; align-items: center; gap: 7px; background: var(--bg); border-radius: 7px; padding: 7px 9px; }
.batch-label { font-size: 11px; color: var(--text-3); flex-shrink: 0; }
.batch-date { flex: 1; border: 1px solid var(--border); border-radius: 6px; padding: 5px 8px; font-size: 12px; color: var(--text); background: var(--surface); font-family: inherit; outline: none; min-width: 0; }
.batch-date:focus { border-color: var(--green); }
.qty-ctrl { display: flex; align-items: center; gap: 5px; flex-shrink: 0; }
.qty-btn { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--border); background: var(--surface); display: flex; align-items: center; justify-content: center; font-size: 17px; font-weight: 300; line-height: 1; color: var(--text-2); cursor: pointer; user-select: none; flex-shrink: 0; }
.qty-btn:active { background: var(--border); }
.qty-num { font-size: 15px; font-weight: 800; color: var(--green); width: 40px; text-align: center; border: 1.5px solid var(--border); border-radius: 6px; padding: 3px 4px; background: var(--surface); outline: none; font-family: inherit; -moz-appearance: textfield; }
.qty-num:focus { border-color: var(--green); }
.qty-num::-webkit-outer-spin-button, .qty-num::-webkit-inner-spin-button { -webkit-appearance: none; }
.batch-del { width: 22px; height: 22px; border-radius: 50%; background: var(--danger-bg); border: none; display: flex; align-items: center; justify-content: center; font-size: 11px; cursor: pointer; color: var(--danger); flex-shrink: 0; }
.add-batch-btn { display: flex; align-items: center; gap: 5px; margin-top: 7px; background: none; border: 1px dashed var(--green-mid); border-radius: 7px; padding: 5px 10px; font-size: 12px; color: var(--green-mid); font-family: inherit; cursor: pointer; width: 100%; justify-content: center; }
.add-batch-btn:active { background: var(--green-light); }

/* 回庫表單 */
.ret-item { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 11px 12px; margin-bottom: 8px; }
.ret-top { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
.ret-name { font-size: 13px; font-weight: 600; color: var(--text); flex: 1; }
.ret-orig { font-size: 11px; color: var(--text-3); }
.ret-batch-row { display: flex; align-items: center; gap: 7px; background: var(--bg); border-radius: 7px; padding: 7px 9px; margin-bottom: 5px; }
.ret-batch-label { font-size: 11px; color: var(--text-3); flex-shrink: 0; min-width: 70px; }
.ret-batch-exp { font-size: 12px; color: var(--text-2); flex: 1; }

/* 訂單對比區塊 */
.order-block { background: var(--gold-light); border: 1.5px solid var(--gold-border); border-radius: var(--radius); padding: 12px 14px; margin-bottom: 14px; }
.order-hd { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
.order-hd-label { font-size: 12px; font-weight: 700; color: var(--gold-dark); text-transform: uppercase; letter-spacing: .4px; }
.order-hd-time { font-size: 11px; color: var(--text-3); margin-left: auto; }
.order-rows { display: flex; flex-direction: column; gap: 6px; }
.order-row { background: var(--surface); border-radius: 7px; padding: 8px 10px; }
.order-row-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
.order-pname { font-size: 12px; font-weight: 600; color: var(--text); }
.order-compare { display: flex; gap: 12px; }
.oc-item { font-size: 11px; color: var(--text-3); }
.oc-item span { font-weight: 700; color: var(--text); }
.oc-item.ok span { color: var(--success); }
.oc-item.warn span { color: var(--danger); }
.anomaly-badge { display: inline-flex; align-items: center; gap: 4px; background: var(--danger-bg); color: var(--danger); font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 20px; }

/* 備註、送出 */
.field-label { font-size: 12px; font-weight: 700; color: var(--text-2); margin-bottom: 6px; }
.note-input { width: 100%; background: var(--bg); border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; font-size: 13px; color: var(--text); font-family: inherit; resize: none; outline: none; margin-bottom: 16px; min-height: 60px; }
.note-input:focus { border-color: var(--green); }
.note-input::placeholder { color: var(--text-3); }
.submit-btn { width: 100%; background: var(--green); color: #fff; border: none; border-radius: var(--radius); padding: 15px; font-size: 15px; font-weight: 700; cursor: pointer; font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 8px; transition: opacity .15s; }
.submit-btn:active { opacity: .88; }
.submit-btn:disabled { opacity: .4; cursor: not-allowed; }
.submit-btn .gold { color: var(--gold); }
.back-btn { flex: 0 0 80px; background: var(--bg); color: var(--text-2); border: 1.5px solid var(--border); border-radius: var(--radius); padding: 15px; font-size: 14px; font-weight: 600; cursor: pointer; font-family: inherit; }

/* 空狀態 */
.empty-hint { text-align: center; color: var(--text-3); font-size: 13px; padding: 16px 0; }
.rlabel { font-size: 11px; font-weight: 700; color: var(--text-3); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 7px; }

/* Toast */
.toast { position: fixed; bottom: 88px; left: 50%; transform: translateX(-50%) translateY(16px); background: var(--green); color: #fff; padding: 10px 22px; border-radius: 24px; font-size: 13px; font-weight: 600; opacity: 0; transition: opacity .22s, transform .22s; z-index: 999; white-space: nowrap; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* Page */
.page { display: none; }
.page.active { display: block; }
.pg-hd { background: var(--green); padding: 52px 18px 16px; }
.pg-hd-title { color: #fff; font-size: 19px; font-weight: 700; }
.pg-hd-sub { color: rgba(255,255,255,.6); font-size: 12px; margin-top: 3px; }

/* 紀錄頁 */
.log-group { margin: 14px 14px 0; }
.log-date { font-size: 11px; font-weight: 700; color: var(--text-3); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 7px; }
/* ── Mini Modal（選品後彈出效期數量輸入）── */
/* ── 自訂下拉選單（in-flow，不用 absolute）── */
.dropdown-wrap { margin-bottom: 10px; }
.dropdown-trigger {
  display: flex; align-items: center; gap: 8px;
  background: var(--surface); border: 1.5px solid var(--border);
  border-radius: var(--radius-sm); padding: 12px 14px;
  cursor: pointer; transition: border-color .15s; user-select: none;
}
.dropdown-trigger.open { border-color: var(--green); border-radius: var(--radius-sm) var(--radius-sm) 0 0; border-bottom-color: transparent; }
.dropdown-icon { font-size: 15px; flex-shrink: 0; }
.dropdown-placeholder { flex: 1; font-size: 14px; color: var(--text-3); }
.dropdown-placeholder.selected { color: var(--text); font-weight: 600; }
.dropdown-arrow { font-size: 11px; color: var(--text-3); flex-shrink: 0; transition: transform .2s; }
.dropdown-arrow.open { transform: rotate(180deg); }

.dropdown-panel {
  display: none; flex-direction: column;
  border: 1.5px solid var(--green); border-top: none;
  border-radius: 0 0 var(--radius-sm) var(--radius-sm);
  background: var(--surface); margin-bottom: 12px;
  max-height: 420px; overflow: hidden;
}
.dropdown-panel.open { display: flex; }
.dropdown-search-row {
  padding: 8px 10px; border-bottom: 1px solid var(--border);
  flex-shrink: 0; background: var(--surface);
}
.dropdown-search {
  width: 100%; background: var(--bg); border: 1px solid var(--border);
  border-radius: 6px; padding: 8px 12px; font-size: 13px;
  color: var(--text); font-family: inherit; outline: none;
}
.dropdown-search:focus { border-color: var(--green); }
.dropdown-search::placeholder { color: var(--text-3); }
.dropdown-items { overflow-y: auto; flex: 1; }
.dropdown-item {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 14px; cursor: pointer;
  border-bottom: 1px solid var(--border); transition: background .1s;
}
.dropdown-item:last-child { border-bottom: none; }
.dropdown-item:active, .dropdown-item:hover { background: var(--green-light); }
.di-ico { font-size: 16px; flex-shrink: 0; }
.di-info { flex: 1; min-width: 0; }
.di-name { font-size: 13px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.di-meta { font-size: 11px; color: var(--text-3); margin-top: 1px; }
.di-unit { font-size: 12px; color: var(--text-2); font-weight: 600; flex-shrink: 0; background: var(--green-light); padding: 2px 7px; border-radius: 10px; }
/* ── 選定品項輸入卡 ── */
.selected-product-card { background: var(--green-pale); border: 1.5px solid var(--green-light); border-radius: var(--radius); padding: 14px; margin-bottom: 12px; }
.spc-top { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; padding-bottom: 12px; border-bottom: 1px solid var(--green-light); }
.spc-ico { font-size: 20px; }
.spc-info { flex: 1; }
.spc-name { font-size: 14px; font-weight: 700; color: var(--green); }
.spc-code { font-size: 11px; color: var(--text-3); margin-top: 2px; }
.spc-change { font-size: 12px; color: var(--green-mid); font-weight: 600; cursor: pointer; text-decoration: underline; flex-shrink: 0; }
.spc-batches { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
.spc-batch-row { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; display: flex; align-items: center; gap: 8px; }
.spc-batch-label { font-size: 12px; color: var(--text-3); flex-shrink: 0; min-width: 44px; }
.spc-date { flex: 1; border: 1px solid var(--border); border-radius: 6px; padding: 6px 8px; font-size: 13px; color: var(--text); background: var(--bg); font-family: inherit; outline: none; min-width: 0; }
.spc-date:focus { border-color: var(--green); }
.spc-unit { font-size: 11px; color: var(--text-3); flex-shrink: 0; }
.spc-batch-del { width: 22px; height: 22px; border-radius: 50%; background: var(--danger-bg); border: none; display: flex; align-items: center; justify-content: center; font-size: 11px; cursor: pointer; color: var(--danger); flex-shrink: 0; }
.spc-add-batch { width: 100%; background: none; border: 1px dashed var(--green-mid); border-radius: 7px; padding: 7px; font-size: 12px; color: var(--green-mid); font-family: inherit; cursor: pointer; margin-bottom: 12px; }
.spc-add-batch:active { background: var(--green-light); }
.spc-confirm { width: 100%; background: var(--green); color: #fff; border: none; border-radius: var(--radius-sm); padding: 12px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 6px; }
.spc-confirm:active { opacity: .88; }
.spc-confirm .gold { color: var(--gold); }

/* ── 已選清單品項列 ── */
.sel-list-item { display: flex; align-items: center; gap: 8px; padding: 8px 0; border-bottom: 1px solid var(--border); }
.sel-list-item:last-child { border-bottom: none; }
.sli-ico { font-size: 15px; }
.sli-info { flex: 1; min-width: 0; }
.sli-name { font-size: 13px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
