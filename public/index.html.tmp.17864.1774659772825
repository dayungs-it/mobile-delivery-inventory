// 展開輸入區
function renderInputArea() {
  const p = currentProduct;
  document.getElementById('goInputArea').style.display = '';
  const minDate = today();
  const batchRows = currentBatches.map((b, bi) => `
    <div class="spc-batch-row">
      <div class="spc-batch-label">批次 ${bi + 1}</div>
      <input class="spc-date" type="date" value="${b.date}" min="${minDate}"
        onchange="setBatch(${bi},this.value)">
      <div class="qty-ctrl">
        <div class="qty-btn" onclick="setBatchQtyInline(${bi},-1)">−</div>
        <input class="qty-num" type="number" id="ibq-${bi}" value="${b.qty}" min="1"
          oninput="currentBatches[${bi}].qty=parseInt(this.value)||0">
        <div class="qty-btn" onclick="setBatchQtyInline(${bi},1)">+</div>
      </div>
      <span class="spc-unit">${p.unit || '件'}</span>
      ${currentBatches.length > 1 ? `<button class="spc-batch-del" onclick="delBatchInline(${bi})">✕</button>` : ''}
    </div>`).join('');
  document.getElementById('selectedProductCard').innerHTML = `
    <div class="spc-top">
      <div class="spc-ico">${p.icon}</div>
      <div class="spc-info">
        <div class="spc-name">${p.name}</div>
        <div class="spc-code">${p.code}${p.spec ? '・' + p.spec : ''}</div>
      </div>
      <span class="spc-change" onclick="clearProduct()">重新選擇</span>
    </div>
    <div id="spcBatches">${batchRows}</div>
    <button class="spc-add-batch" onclick="addBatchInline()">+ 新增另一批效期</button>
    <button class="spc-confirm" onclick="confirmAdd()">加入清單 <span class="gold">+</span></button>`;
}
function setBatch(bi, val) { currentBatches[bi].date = val; }
function setBatchQtyInline(bi, d) {
  const el = document.getElementById('ibq-' + bi);
  const cur = parseInt(el.value) || 1;
  const next = Math.max(1, cur + d);
  currentBatches[bi].qty = next;
  el.value = next;
}
function addBatchInline() { currentBatches.push({ date: '', qty: 1 }); renderInputArea(); }
function delBatchInline(bi) { currentBatches.splice(bi, 1); renderInputArea(); }

function confirmAdd() {
  if (!currentProduct) return;
  if (currentBatches.some(b => !b.date)) { showToast('請填寫所有批次的效期'); return; }
  // 直接讀取所有 qty-num input 的當前值更新 currentBatches
  const qtyInputs = document.querySelectorAll('#selectedProductCard .qty-num');
  qtyInputs.forEach((el, bi) => {
    if (bi < currentBatches.length) {
      currentBatches[bi].qty = parseInt(el.value) || 0;
    }
  });
  // 驗證每批次數量
  const invalid = currentBatches.some(b => !b.qty || b.qty <= 0);
  if (invalid) { showToast('數量不可為空或 0'); return; }
  const code = currentProduct.code;
  if (!selected[code]) {
    selected[code] = { ...currentProduct, batches: JSON.parse(JSON.stringify(currentBatches)) };
  } else {
    currentBatches.forEach(nb => {
      const exist = selected[code].batches.find(b => b.date === nb.date);
      if (exist) exist.qty += nb.qty; else selected[code].batches.push({ ...nb });
    });
  }
  showToast('✓ 已加入：' + currentProduct.name);
  clearProduct();
  renderSelList();
}

