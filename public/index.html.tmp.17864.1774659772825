      ).join('');
      return `<div class="mob-card rtn">
        <div class="mc-name">${it.name}</div>
        <div class="mc-batches">${batchRows}</div>
      </div>`;
    }).join('');
    return `<div class="dispatch-card" style="padding:0;overflow:hidden">
      <div class="dc-top" style="padding:10px 14px 10px">
        <div class="dc-tag" style="background:#faf7ed;color:var(--gold-dark)">收退換貨</div>
        <div class="dc-time">${d.time}</div>
      </div>
      <div style="border-top:1px solid var(--border)">${cards}</div>
      <div class="dc-bottom" style="padding:8px 14px"><div class="dc-consume">已入庫</div></div>
    </div>`;
  }

  // 一般出門 / 回庫型別
  const cards = Object.values(d.items).map(it => {
    const hasRet = it.returned !== null && it.returned !== undefined;
    const totalTaken = it.batches.reduce((a, b) => a + b.qty, 0);
    const isSingle = it.batches.length === 1;

    const batchRows = it.batches.map((b, bi) => {
      const isLast = bi === it.batches.length - 1;
      // 找對應效期的繳回數
      const retBatch = it.returnBatches
        ? it.returnBatches.find(rb => rb.date === b.date)
        : null;
      const retQty = retBatch ? retBatch.qty : null;
      return `<div class="mc-batch-row">
        <span class="mc-exp" style="margin:0">效期 ${b.date}</span>
        <span class="mc-nums" style="gap:8px">
          <span class="mc-n">帶出 <b>${b.qty}</b></span>
          ${hasRet && retQty !== null ? `<span class="mc-n">繳回 <b>${retQty}</b></span>` : ''}
          ${hasRet && retQty === null && isSingle ? `<span class="mc-n">繳回 <b>${it.returned}</b></span>` : ''}
          ${!hasRet ? `<span class="mc-n warn">未繳回</span>` : ''}
        </span>
      </div>`;
    }).join('');

    return `<div class="mob-card">
      <div class="mc-name">${it.name}</div>
      <div class="mc-batches">${batchRows}</div>
    </div>`;
  }).join('');

  return `<div class="dispatch-card" style="padding:0;overflow:hidden">
    <div class="dc-top" style="padding:10px 14px 10px">
      <div class="dc-tag ${d.status === 'out' ? 'out' : 'done'}">${d.status === 'out' ? '出門中' : '已回庫'}</div>
      ${d.anomaly ? '<div class="dc-anomaly">⚠ 數量異常</div>' : ''}
      <div class="dc-time">${d.time}</div>
    </div>
    <div style="border-top:1px solid var(--border)">${cards}</div>
    <div class="dc-bottom" style="padding:8px 14px">
      <div class="dc-consume">${d.status === 'out' ? '尚未回庫' : '已完成'}</div>
    </div>
  </div>`;
}

