      });
    }
  });
  const missing = Object.entries(outItems)
    .filter(([code]) => !retSelected[code])
    .map(([, name]) => name);
  if (missing.length > 0) {
    showToast('尚未輸入：' + missing.slice(0, 2).join('、') + (missing.length > 2 ? ` 等 ${missing.length} 項` : ''));
    return;
  }
  // 隱藏步驟1所有區塊
  document.getElementById('retDropdownWrap').style.display = 'none';
  document.getElementById('retInputArea').style.display = 'none';
  document.getElementById('retSelWrap').style.display = 'none';
  document.getElementById('retSubmitArea').style.display = 'none';
  document.getElementById('returnSection').style.display = 'none';
  document.getElementById('retSectionLabel1').style.display = 'none';
  document.getElementById('retSectionDivider').style.display = 'none';
  document.getElementById('retSectionLabel2').style.display = 'none';
  document.getElementById('ret-s2').style.display = '';

  const orderBlock = document.getElementById('orderBlock');
  orderBlock.innerHTML = `
    <div class="order-hd"><div class="order-hd-label">📋 訂單核對結果</div></div>
    <div style="text-align:center;padding:20px 0;color:var(--text-3);font-size:13px;">
      <div style="margin-bottom:8px">查詢訂單中…</div>
      <div style="width:32px;height:32px;border:3px solid var(--gold-border);border-top-color:var(--gold-dark);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto"></div>
    </div>`;

  // 組合回庫資料
  const returnedData = {};
  Object.entries(retSelected).forEach(([code, it]) => {
    const taken = it.takenBatches.reduce((a, b) => a + b.qty, 0);
    const returned = it.returnBatches.reduce((a, b) => a + b.qty, 0);
    returnedData[code] = { name: it.name, icon: it.icon, taken, returned, consumed: taken - returned, isReturn: false };
  });
  // 退換貨品項加入顯示（標記 isReturn）
  Object.entries(rtnSelected).forEach(([code, it]) => {
    const qty = it.batches.reduce((a, b) => a + b.qty, 0);
    if (returnedData[code]) {
      returnedData[code].returnQty = qty;
    } else {
      returnedData[code] = { name: it.name, icon: it.icon, taken: 0, returned: qty, consumed: 0, isReturn: true };
    }
  });

  const retCodes = Object.keys(retSelected);
  try {
    const apiData = retCodes.length ? await fetchOrderData(retCodes) : null;
    renderOrderCompare(returnedData, apiData);
  } catch (err) {
    renderOrderCompare(returnedData, null, err.message);
